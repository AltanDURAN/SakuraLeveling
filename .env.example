DISCORD_TOKEN=your_discord_bot_token_here
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/lita_v2
ENV=development
DEBUG=true
BETA_CHANNEL_ID=
ENCOUNTER_CHANNEL_ID=
# Channel des world bosses. Si vide ou 0, fallback vers ENCOUNTER_CHANNEL_ID.
# IDs de référence fournis par le user :
#   • prod / beta : 1500256259687972915
#   • dev (local) : 1421477764099342377
BOSS_CHANNEL_ID=
# URL publique du webapp skill tree (bouton 'Vue détaillée' du /skill).
# Local : http://localhost:8000  /  Prod : http://<IP_VPS>/  ou https://ton-domaine.com/
WEBAPP_BASE_URL=http://localhost:8000
# Liste des Discord IDs admins (séparés par des virgules) pour les commandes /admin
ADMIN_DISCORD_IDS=

# --- Webapp admin (OAuth Discord) ---
# Client ID/secret de l'app Discord (Developer Portal > OAuth2).
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# URL EXACTE à enregistrer dans Discord Portal > OAuth2 > Redirects.
# Ex prod : http://<IP_VPS>:8001/admin/auth/callback
OAUTH_REDIRECT_URI=http://localhost:8001/admin/auth/callback
# Secret de signature des cookies de session admin (itsdangerous).
# OBLIGATOIRE : la webapp REFUSE de démarrer si ce secret reste au défaut.
# Générer : python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SESSION_SECRET=